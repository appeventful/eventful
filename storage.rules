rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Yardımcı fonksiyonlar
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Profil Fotoğrafları Kuralları
    match /profile_pics/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Etkinlik Resimleri Kuralları
    match /event_images/{eventId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Etkinliği oluşturan herkes yükleyebilir
    }

    // Etkinlik Fotoğraf Paylaşımı (Moderatörlü)
    match /event_photos/{eventId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Katılımcılar yükleyebilir
    }

    // Genel Kurallar (Hata durumunda fallback)
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
